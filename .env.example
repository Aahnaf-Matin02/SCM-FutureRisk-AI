# ─────────────────────────────────────────────────────────────────────────────
# SCM FutureRisk AI — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   streamlit run app.py
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
# Used for: AI-powered strategic recommendations in Claude Decision Room
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Google Custom Search API Key
# Get yours at: https://developers.google.com/custom-search/v1/introduction
# Used for: Real-time supply chain news and signal collection
SEARCH_API_KEY=YOUR_GOOGLE_SEARCH_API_KEY

# Google Custom Search Engine ID (cx)
# Create a search engine at: https://programmablesearchengine.google.com
# Configure it to search the entire web for best results
SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID

# ─────────────────────────────────────────────────────────────────────────────
# NOTES:
# - The app works in Demo Mode without any API keys.
# - Demo Mode uses curated static supply chain signals.
# - Claude Decision Room falls back to rule-based logic without ANTHROPIC_API_KEY.
# - Global Risk Monitor uses curated demo articles without SEARCH_API_KEY.
# ─────────────────────────────────────────────────────────────────────────────
